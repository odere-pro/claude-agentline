{
  // Markdown linting for the agentline plugin.
  // Only the rules we deliberately diverge from upstream defaults are listed.
  "default": true,
  "MD003": { "style": "atx" },
  "MD004": { "style": "dash" },
  "MD007": { "indent": 2 },
  "MD012": false,
  "MD013": false,
  "MD024": { "siblings_only": true },
  "MD026": { "punctuation": ".,;:!" },
  "MD029": { "style": "ordered" },
  "MD033": { "allowed_elements": ["br", "kbd", "details", "summary"] },
  "MD040": false,
  "MD041": false,
  "MD046": { "style": "fenced" },
  "MD048": { "style": "backtick" },
  "MD060": false
}
