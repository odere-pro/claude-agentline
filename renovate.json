{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:recommended"],
  "timezone": "UTC",
  "schedule": ["before 9am on monday"],
  "labels": ["dependencies"],
  "dependencyDashboard": true,
  "rangeStrategy": "replace",
  "minimumReleaseAge": "3 days",
  "internalChecksFilter": "strict",
  "lockFileMaintenance": {
    "enabled": true,
    "schedule": ["before 9am on monday"]
  },
  "packageRules": [
    {
      "description": "Batch non-major dev dependency bumps into one PR.",
      "matchDepTypes": ["devDependencies"],
      "matchUpdateTypes": ["minor", "patch", "pin", "digest"],
      "groupName": "dev dependencies (non-major)"
    },
    {
      "description": "Runtime deps are exact-pinned (CLAUDE.md house rule); keep them exact and review individually.",
      "matchDepTypes": ["dependencies"],
      "rangeStrategy": "pin"
    },
    {
      "description": "Keep GitHub Actions pinned to a full commit digest (supply-chain invariant) while still updating them.",
      "matchManagers": ["github-actions"],
      "pinDigests": true,
      "groupName": "github actions"
    }
  ],
  "vulnerabilityAlerts": {
    "labels": ["security"]
  }
}
