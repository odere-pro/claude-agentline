{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://raw.githubusercontent.com/odere-pro/claude-agentline/main/schemas/config.schema.json",
  "title": "agentline configuration",
  "description": "Schema for agentline statusline configuration.",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "$schema": { "type": "string" },
    "version": { "type": "integer", "enum": [1], "default": 1 },
    "theme": { "type": ["string", "null"], "default": null },
    "lines": { "type": "array", "minItems": 1, "items": { "$ref": "#/definitions/line" } },
    "global": { "$ref": "#/definitions/global" },
    "powerline": { "$ref": "#/definitions/powerline" },
    "terminalWidth": { "$ref": "#/definitions/terminalWidth" },
    "keymap": { "type": "object", "additionalProperties": { "type": "string" }, "default": {} },
    "language": { "type": "string", "minLength": 1, "default": "en" },
    "refreshInterval": { "type": "integer", "minimum": 0, "default": 5 },
    "families": {
      "type": "object",
      "additionalProperties": false,
      "default": {},
      "properties": {
        "session": { "$ref": "#/definitions/familyIdentity" },
        "tokens": { "$ref": "#/definitions/familyIdentity" },
        "context": { "$ref": "#/definitions/familyIdentity" },
        "rate-limits": { "$ref": "#/definitions/familyIdentity" },
        "git": { "$ref": "#/definitions/familyIdentity" }
      }
    },
    "translations": {
      "type": "object",
      "default": {},
      "additionalProperties": { "type": "object", "additionalProperties": { "type": "string" } }
    }
  },
  "required": ["version"],
  "definitions": {
    "colour": {
      "oneOf": [
        {
          "type": "string",
          "enum": [
            "black",
            "red",
            "green",
            "yellow",
            "blue",
            "magenta",
            "cyan",
            "white",
            "bright-black",
            "bright-red",
            "bright-green",
            "bright-yellow",
            "bright-blue",
            "bright-magenta",
            "bright-cyan",
            "bright-white"
          ]
        },
        {
          "type": "string",
          "pattern": "^colour:([0-9]|[1-9][0-9]|1[0-9]{2}|2[0-4][0-9]|25[0-5])$"
        },
        { "type": "string", "pattern": "^#[0-9a-fA-F]{6}$" }
      ]
    },
    "colourOrNull": { "oneOf": [{ "$ref": "#/definitions/colour" }, { "type": "null" }] },
    "familyIdentity": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "glyph": { "type": "string" },
        "glyphAscii": { "type": "string" },
        "colour": { "$ref": "#/definitions/colour" }
      }
    },
    "stringOrStringArray": {
      "oneOf": [
        { "type": "string" },
        { "type": "array", "items": { "type": "string" }, "minItems": 1 }
      ]
    },
    "line": {
      "type": "object",
      "additionalProperties": false,
      "required": ["widgets"],
      "properties": {
        "widgets": { "type": "array", "minItems": 0, "items": { "$ref": "#/definitions/widget" } }
      }
    },
    "widget": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type"],
      "properties": {
        "type": {
          "type": "string",
          "enum": [
            "account-email",
            "added-dirs",
            "agent-name",
            "api-duration",
            "clock",
            "context-200k-flag",
            "context-percentage",
            "cost-burn-rate",
            "cost-efficiency",
            "cost-usd",
            "cost-vs-limit",
            "current-session-reset-timer",
            "cwd-path",
            "git-ahead-behind",
            "git-branch",
            "git-changes",
            "git-conflicts",
            "git-origin-repo",
            "git-pr",
            "git-upstream",
            "git-worktree",
            "lines-changed",
            "model",
            "output-style",
            "plan",
            "project",
            "project-dir",
            "session-duration",
            "session-id",
            "session-weekly-usage",
            "thinking-effort",
            "thinking-enabled",
            "token-speed",
            "tokens",
            "tokens-cached",
            "version",
            "vim-mode",
            "week-limit-timer"
          ]
        },
        "id": { "type": "string" },
        "fg": { "$ref": "#/definitions/colourOrNull" },
        "bg": { "$ref": "#/definitions/colourOrNull" },
        "bold": { "type": "boolean", "default": false },
        "italic": { "type": "boolean", "default": false },
        "rawValue": { "type": "boolean", "default": false },
        "merged": {
          "type": "string",
          "enum": ["off", "merge", "merge-no-padding"],
          "default": "off"
        },
        "hidden": { "type": "boolean", "default": false },
        "options": {
          "type": "object",
          "additionalProperties": true,
          "description": "Per-widget option bag. `label` is the universal option (a prefix every widget reads via settings.options.label); other keys and their value ranges are validated against the widget catalogue by `agentline config widget add` / `set-option`."
        }
      }
    },
    "global": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "padding": { "type": "integer", "minimum": 0, "default": 1 },
        "separator": { "type": "string", "default": "|" },
        "valueSeparator": { "type": "string", "default": "·" },
        "inheritColors": { "type": "boolean", "default": false },
        "bold": { "type": "boolean", "default": false },
        "italic": { "type": "boolean", "default": false },
        "minimalist": { "type": "boolean", "default": false },
        "overrideFg": { "$ref": "#/definitions/colourOrNull", "default": null },
        "overrideBg": { "$ref": "#/definitions/colourOrNull", "default": null }
      }
    },
    "powerline": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "enabled": { "type": "boolean", "default": false },
        "theme": { "type": ["string", "null"], "default": null },
        "caps": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "start": { "$ref": "#/definitions/stringOrStringArray", "default": "" },
            "end": { "$ref": "#/definitions/stringOrStringArray", "default": "" }
          }
        },
        "autoAlign": { "type": "boolean", "default": false },
        "continueColors": { "type": "boolean", "default": false },
        "glyphs": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "hardRight": { "$ref": "#/definitions/stringOrStringArray" },
            "softRight": { "$ref": "#/definitions/stringOrStringArray" },
            "hardLeft": { "$ref": "#/definitions/stringOrStringArray" },
            "softLeft": { "$ref": "#/definitions/stringOrStringArray" }
          }
        }
      }
    },
    "terminalWidth": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "mode": {
          "type": "string",
          "enum": ["full", "full-minus-40", "full-until-compact"],
          "default": "full-minus-40"
        },
        "compactThreshold": { "type": "integer", "minimum": 1, "default": 60 }
      }
    }
  }
}
