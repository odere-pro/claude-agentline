{
  "$id": "https://raw.githubusercontent.com/odere-pro/claude-agentline/main/schemas/theme.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "agentline theme",
  "type": "object",
  "required": ["name", "palette"],
  "additionalProperties": false,
  "properties": {
    "$schema": { "type": "string" },
    "name": {
      "type": "string",
      "pattern": "^[a-z0-9]+(-[a-z0-9]+)*$",
      "minLength": 1,
      "maxLength": 64
    },
    "palette": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "accent",
        "info",
        "success",
        "warning",
        "danger",
        "muted",
        "git-clean",
        "git-dirty",
        "tokens-low",
        "tokens-mid",
        "tokens-high",
        "bg-section",
        "bg-emphasis"
      ],
      "properties": {
        "accent": {
          "type": "string",
          "pattern": "^(#[0-9a-fA-F]{6}|colour:(0|[1-9]\\d?|1\\d\\d|2[0-4]\\d|25[0-5])|black|red|green|yellow|blue|magenta|cyan|white|bright-(black|red|green|yellow|blue|magenta|cyan|white))$"
        },
        "info": {
          "type": "string",
          "pattern": "^(#[0-9a-fA-F]{6}|colour:(0|[1-9]\\d?|1\\d\\d|2[0-4]\\d|25[0-5])|black|red|green|yellow|blue|magenta|cyan|white|bright-(black|red|green|yellow|blue|magenta|cyan|white))$"
        },
        "success": {
          "type": "string",
          "pattern": "^(#[0-9a-fA-F]{6}|colour:(0|[1-9]\\d?|1\\d\\d|2[0-4]\\d|25[0-5])|black|red|green|yellow|blue|magenta|cyan|white|bright-(black|red|green|yellow|blue|magenta|cyan|white))$"
        },
        "warning": {
          "type": "string",
          "pattern": "^(#[0-9a-fA-F]{6}|colour:(0|[1-9]\\d?|1\\d\\d|2[0-4]\\d|25[0-5])|black|red|green|yellow|blue|magenta|cyan|white|bright-(black|red|green|yellow|blue|magenta|cyan|white))$"
        },
        "danger": {
          "type": "string",
          "pattern": "^(#[0-9a-fA-F]{6}|colour:(0|[1-9]\\d?|1\\d\\d|2[0-4]\\d|25[0-5])|black|red|green|yellow|blue|magenta|cyan|white|bright-(black|red|green|yellow|blue|magenta|cyan|white))$"
        },
        "muted": {
          "type": "string",
          "pattern": "^(#[0-9a-fA-F]{6}|colour:(0|[1-9]\\d?|1\\d\\d|2[0-4]\\d|25[0-5])|black|red|green|yellow|blue|magenta|cyan|white|bright-(black|red|green|yellow|blue|magenta|cyan|white))$"
        },
        "git-clean": {
          "type": "string",
          "pattern": "^(#[0-9a-fA-F]{6}|colour:(0|[1-9]\\d?|1\\d\\d|2[0-4]\\d|25[0-5])|black|red|green|yellow|blue|magenta|cyan|white|bright-(black|red|green|yellow|blue|magenta|cyan|white))$"
        },
        "git-dirty": {
          "type": "string",
          "pattern": "^(#[0-9a-fA-F]{6}|colour:(0|[1-9]\\d?|1\\d\\d|2[0-4]\\d|25[0-5])|black|red|green|yellow|blue|magenta|cyan|white|bright-(black|red|green|yellow|blue|magenta|cyan|white))$"
        },
        "tokens-low": {
          "type": "string",
          "pattern": "^(#[0-9a-fA-F]{6}|colour:(0|[1-9]\\d?|1\\d\\d|2[0-4]\\d|25[0-5])|black|red|green|yellow|blue|magenta|cyan|white|bright-(black|red|green|yellow|blue|magenta|cyan|white))$"
        },
        "tokens-mid": {
          "type": "string",
          "pattern": "^(#[0-9a-fA-F]{6}|colour:(0|[1-9]\\d?|1\\d\\d|2[0-4]\\d|25[0-5])|black|red|green|yellow|blue|magenta|cyan|white|bright-(black|red|green|yellow|blue|magenta|cyan|white))$"
        },
        "tokens-high": {
          "type": "string",
          "pattern": "^(#[0-9a-fA-F]{6}|colour:(0|[1-9]\\d?|1\\d\\d|2[0-4]\\d|25[0-5])|black|red|green|yellow|blue|magenta|cyan|white|bright-(black|red|green|yellow|blue|magenta|cyan|white))$"
        },
        "bg-section": {
          "type": "string",
          "pattern": "^(#[0-9a-fA-F]{6}|colour:(0|[1-9]\\d?|1\\d\\d|2[0-4]\\d|25[0-5])|black|red|green|yellow|blue|magenta|cyan|white|bright-(black|red|green|yellow|blue|magenta|cyan|white))$"
        },
        "bg-emphasis": {
          "type": "string",
          "pattern": "^(#[0-9a-fA-F]{6}|colour:(0|[1-9]\\d?|1\\d\\d|2[0-4]\\d|25[0-5])|black|red|green|yellow|blue|magenta|cyan|white|bright-(black|red|green|yellow|blue|magenta|cyan|white))$"
        },
        "effort-ultracode": {
          "type": "string",
          "pattern": "^(#[0-9a-fA-F]{6}|colour:(0|[1-9]\\d?|1\\d\\d|2[0-4]\\d|25[0-5])|black|red|green|yellow|blue|magenta|cyan|white|bright-(black|red|green|yellow|blue|magenta|cyan|white))$"
        }
      }
    },
    "powerline": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "caps.start": { "type": "string", "maxLength": 4 },
        "caps.end": { "type": "string", "maxLength": 4 }
      }
    }
  }
}
