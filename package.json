{
  "name": "@agentline/cli",
  "version": "0.1.0",
  "description": "Standalone Claude Code statusline CLI: reads stdin JSON, writes ANSI-styled output.",
  "author": {
    "name": "agentline maintainers",
    "url": "https://github.com/odere-pro/claude-agentline"
  },
  "homepage": "https://github.com/odere-pro/claude-agentline",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/odere-pro/claude-agentline.git"
  },
  "bugs": {
    "url": "https://github.com/odere-pro/claude-agentline/issues"
  },
  "license": "MIT",
  "keywords": [
    "claude-code",
    "statusline",
    "cli",
    "ansi",
    "terminal",
    "powerline"
  ],
  "engines": {
    "node": ">=20"
  },
  "type": "module",
  "bin": {
    "agentline": "dist/cli.mjs"
  },
  "files": [
    "dist/",
    "schemas/",
    "themes/",
    "templates/",
    "LICENSE",
    "README.md",
    "CHANGELOG.md"
  ],
  "dependencies": {
    "ajv": "8.20.0",
    "ajv-formats": "3.0.1",
    "ink": "5.0.1",
    "react": "18.3.1"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "@types/react": "^18.3.18",
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "eslint": "^8.57.0",
    "prettier": "^3.3.3",
    "tsup": "^8.3.0",
    "typescript": "^5.6.0",
    "vitest": "^4.1.5"
  },
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint \"src/**/*.ts\"",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write \"**/*.{ts,json,md}\"",
    "format:check": "prettier --check \"**/*.{ts,json,md}\"",
    "prepublishOnly": "npm run build"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  }
}
