{
  "name": "@odere-pro/agentline",
  "version": "0.1.0",
  "description": "Standalone Claude Code statusline CLI: reads stdin JSON, writes ANSI-styled output.",
  "author": {
    "name": "agentline maintainers",
    "url": "https://github.com/odere-pro/claude-agentline"
  },
  "homepage": "https://github.com/odere-pro/claude-agentline",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/odere-pro/claude-agentline.git"
  },
  "bugs": {
    "url": "https://github.com/odere-pro/claude-agentline/issues"
  },
  "license": "MIT",
  "keywords": [
    "claude-code",
    "statusline",
    "cli",
    "ansi",
    "terminal",
    "powerline"
  ],
  "engines": {
    "node": ">=20.19",
    "pnpm": ">=9.15"
  },
  "packageManager": "pnpm@10.33.4",
  "type": "module",
  "bin": {
    "agentline": "dist/cli.mjs"
  },
  "files": [
    "dist/",
    "schemas/",
    "scripts/",
    "themes/",
    "templates/",
    "LICENSE",
    "README.md",
    "CHANGELOG.md"
  ],
  "dependencies": {
    "ajv": "8.20.0",
    "ink": "5.0.1",
    "react": "18.3.1"
  },
  "devDependencies": {
    "@types/node": "20.19.41",
    "@types/react": "18.3.28",
    "@typescript-eslint/eslint-plugin": "7.18.0",
    "@typescript-eslint/parser": "7.18.0",
    "@vitest/coverage-v8": "4.1.6",
    "esbuild": "0.27.7",
    "eslint": "8.57.1",
    "fast-check": "3.23.2",
    "knip": "6.14.0",
    "prettier": "3.8.3",
    "tsup": "8.5.1",
    "typescript": "5.9.3",
    "vitest": "4.1.6"
  },
  "scripts": {
    "build": "tsup",
    "postinstall": "node scripts/postinstall.mjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint \"src/**/*.ts\"",
    "knip": "knip",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write \"**/*.{ts,json,md}\"",
    "format:check": "prettier --check \"**/*.{ts,json,md}\"",
    "prepublishOnly": "pnpm run build"
  },
  "pnpm": {
    "overrides": {
      "ws@>=8.0.0 <8.20.1": "8.20.1"
    }
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  }
}
