{
  "name": "@odere-pro/agentline",
  "version": "0.1.4",
  "description": "Fast, themeable powerline statusline for Claude Code: git, tokens, context window, rate limits and session info across 27 configurable widgets, with a live TUI editor.",
  "author": {
    "name": "agentline maintainers",
    "url": "https://github.com/odere-pro/claude-agentline"
  },
  "homepage": "https://github.com/odere-pro/claude-agentline",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/odere-pro/claude-agentline.git"
  },
  "bugs": {
    "url": "https://github.com/odere-pro/claude-agentline/issues"
  },
  "license": "MIT",
  "keywords": [
    "claude-code",
    "statusline",
    "status-line",
    "status-bar",
    "cli",
    "ansi",
    "terminal",
    "powerline",
    "prompt",
    "theme",
    "themes",
    "git",
    "tokens",
    "context-window",
    "rate-limit",
    "widget",
    "nerd-font",
    "tui",
    "developer-tools",
    "nodejs",
    "typescript"
  ],
  "engines": {
    "node": ">=20.19",
    "pnpm": ">=9.15"
  },
  "packageManager": "pnpm@10.33.4",
  "type": "module",
  "bin": {
    "agentline": "dist/cli.mjs"
  },
  "files": [
    "dist/",
    "schemas/",
    "scripts/",
    "themes/",
    "templates/",
    "agents/agentline*.md",
    "LICENSE",
    "README.md",
    "CHANGELOG.md"
  ],
  "dependencies": {
    "ajv": "8.20.0",
    "ink": "5.0.1",
    "react": "18.3.1"
  },
  "devDependencies": {
    "@types/node": "25.9.1",
    "@types/react": "18.3.28",
    "@typescript-eslint/eslint-plugin": "7.18.0",
    "@typescript-eslint/parser": "7.18.0",
    "@vitest/coverage-v8": "4.1.6",
    "esbuild": "0.28.0",
    "eslint": "8.57.1",
    "fast-check": "4.8.0",
    "knip": "6.14.2",
    "prettier": "3.8.3",
    "tsup": "8.5.1",
    "typescript": "6.0.3",
    "vitest": "4.1.6"
  },
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint \"src/**/*.ts\"",
    "knip": "knip",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write \"**/*.{ts,json,md}\"",
    "format:check": "prettier --check \"**/*.{ts,json,md}\"",
    "prepublishOnly": "pnpm run build"
  },
  "pnpm": {
    "overrides": {
      "ws@>=8.0.0 <8.20.1": "8.20.1"
    }
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  }
}
